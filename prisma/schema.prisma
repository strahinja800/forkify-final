datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(cuid())
  name      String?
  email     String     @unique
  password  String
  image     String?
  recipes   Recipe[]
  bookmarks Bookmark[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  publisher   String
  sourceUrl   String
  image       String
  servings    Int
  cookingTime Int
  ingredients Json
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceId  String
  snapshot  Json
  createdAt DateTime @default(now())

  @@unique([userId, sourceId])
}
